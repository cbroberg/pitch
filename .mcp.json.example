{
  "_comment": "Copy this file to .mcp.json and replace <PLAINTEXT_KEY> with a real key (Settings → MCP Keys at https://www.cardmem.com or the cardmem_generate_mcp_key MCP tool). .mcp.json is gitignored — never commit your key. Native HTTP transport (not the npx mcp-remote bridge, which timed out the fleet on OAuth-discovery). cardmem-lens is the LOCAL daemon (loopback :7475, no auth) that owns the browser for lens_* tools.",
  "mcpServers": {
    "cardmem": {
      "type": "http",
      "url": "https://services.cardmem.com/mcp",
      "headers": {
        "Authorization": "Bearer <PLAINTEXT_KEY>"
      }
    },
    "cardmem-lens": {
      "type": "http",
      "url": "http://127.0.0.1:7475/mcp"
    }
  }
}
